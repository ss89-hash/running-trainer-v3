{
  "version": 2,
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/static/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "^/(.*\\.css)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/(.*\\.js)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/(.*\\.html)$",
      "dest": "/public/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
